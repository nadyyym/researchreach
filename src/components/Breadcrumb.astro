---
import { breadcrumbSchema } from '../lib/seo';

interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
const allItems = [{ name: 'Home', url: 'https://selltoscientists.com/' }, ...items];
---

<nav class="px-6 py-3 border-b border-line" aria-label="Breadcrumb">
  <ol class="flex items-center gap-2 text-[11px] font-mono text-text-muted">
    {allItems.map((item, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && <span class="text-line-accent">/</span>}
        {i < allItems.length - 1 ? (
          <a href={item.url} class="hover:text-text-bright no-underline transition-colors">{item.name}</a>
        ) : (
          <span class="text-text-dim">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify({ '@context': 'https://schema.org', ...breadcrumbSchema(allItems) })}<\/script>`} />
