---
interface Props {
  id?: string;
  heading?: string;
  subheading?: string;
}

const {
  id = "waitlist",
  heading = "Get early access",
  subheading = "Join 200+ teams already on the waitlist. We're onboarding in waves.",
} = Astro.props;
---

<div id={id} class="bg-navy-700 border border-navy-600 rounded-2xl p-8 md:p-10 w-full">
  <h3 class="font-display text-2xl md:text-3xl font-bold text-white mb-2">{heading}</h3>
  <p class="text-slate text-sm md:text-base mb-8">{subheading}</p>

  <form
    class="flex flex-col gap-4"
    action="https://formspree.io/f/placeholder"
    method="POST"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for={`${id}-name`} class="block text-xs uppercase tracking-widest text-slate mb-2 font-semibold">Full name</label>
        <input
          type="text"
          id={`${id}-name`}
          name="name"
          required
          placeholder="Dr. Jane Smith"
          autocomplete="name"
          class="w-full px-4 py-3 bg-navy-800 border border-navy-600 text-white placeholder-slate text-sm rounded-lg outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors font-body"
        />
      </div>
      <div>
        <label for={`${id}-email`} class="block text-xs uppercase tracking-widest text-slate mb-2 font-semibold">Work email</label>
        <input
          type="email"
          id={`${id}-email`}
          name="email"
          required
          placeholder="you@company.com"
          autocomplete="email"
          class="w-full px-4 py-3 bg-navy-800 border border-navy-600 text-white placeholder-slate text-sm rounded-lg outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors font-body"
        />
      </div>
    </div>

    <div>
      <label for={`${id}-company`} class="block text-xs uppercase tracking-widest text-slate mb-2 font-semibold">Company</label>
      <input
        type="text"
        id={`${id}-company`}
        name="company"
        placeholder="Pfizer, Benchling, Andreessen Horowitz..."
        class="w-full px-4 py-3 bg-navy-800 border border-navy-600 text-white placeholder-slate text-sm rounded-lg outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors font-body"
      />
    </div>

    <div>
      <label for={`${id}-usecase`} class="block text-xs uppercase tracking-widest text-slate mb-2 font-semibold">Use case</label>
      <select
        id={`${id}-usecase`}
        name="use_case"
        required
        class="w-full px-4 py-3 bg-navy-800 border border-navy-600 text-white text-sm rounded-lg outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors font-body appearance-none cursor-pointer"
      >
        <option value="" disabled selected>Select your use case</option>
        <option value="pharma_biotech">Pharma / Biotech outreach</option>
        <option value="scientific_software">Scientific software sales</option>
        <option value="recruiting">Deep tech recruiting</option>
        <option value="vc_investing">VC / Investing</option>
        <option value="other">Other</option>
      </select>
    </div>

    <button
      type="submit"
      class="w-full py-4 px-8 bg-electric text-white font-display font-bold text-sm tracking-wide uppercase rounded-lg hover:bg-electric-dim transition-colors mt-2 cursor-pointer"
    >
      Join the Waitlist →
    </button>

    <p class="text-xs text-slate text-center">
      No spam. GDPR-compliant.
      <a href="/privacy" class="text-electric-bright hover:text-white no-underline hover:underline transition-colors">Privacy Policy</a> applies.
    </p>
  </form>
</div>
