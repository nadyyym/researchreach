---
const pathname = Astro.url.pathname;
---

<header class="grid grid-cols-[180px_1fr_auto] grid-lines border-b border-line sticky top-0 z-40">
  <div class="bg-bg px-6 py-3.5 flex items-center">
    <a href="/" class="font-mono font-bold text-sm tracking-tight text-text-bright no-underline flex items-center gap-2.5">
      <span class="w-2.5 h-2.5 bg-red rotate-12 inline-block"></span>
      SCI-BUY
    </a>
  </div>
  <nav class="bg-bg px-6 py-3.5 hidden md:flex items-center gap-7">
    <a href="/features/" class="text-[11px] font-medium uppercase tracking-[1.2px] text-text-dim hover:text-text-bright no-underline transition-colors">Features</a>
    <a href="/use-cases/" class="text-[11px] font-medium uppercase tracking-[1.2px] text-text-dim hover:text-text-bright no-underline transition-colors">Use Cases</a>
    <a href="/pricing/" class="text-[11px] font-medium uppercase tracking-[1.2px] text-text-dim hover:text-text-bright no-underline transition-colors">Pricing</a>
    <a href="/developers/" class="text-[11px] font-medium uppercase tracking-[1.2px] text-text-dim hover:text-text-bright no-underline transition-colors">Developers</a>
    <div class="relative group">
      <button class="text-[11px] font-medium uppercase tracking-[1.2px] text-text-dim hover:text-text-bright transition-colors cursor-pointer">Browse ▾</button>
      <div class="absolute top-full left-0 mt-1 bg-bg-raised border border-line p-3 hidden group-hover:flex flex-col gap-2 min-w-[160px] z-50">
        <a href="/universities/" class="text-xs text-text-dim hover:text-text-bright no-underline">Universities</a>
        <a href="/fields/" class="text-xs text-text-dim hover:text-text-bright no-underline">Fields</a>
        <a href="/researchers/" class="text-xs text-text-dim hover:text-text-bright no-underline">Researchers</a>
        <a href="/phd/" class="text-xs text-text-dim hover:text-text-bright no-underline">PhD & Postdocs</a>
        <a href="/countries/" class="text-xs text-text-dim hover:text-text-bright no-underline">Countries</a>
        <a href="/agencies/" class="text-xs text-text-dim hover:text-text-bright no-underline">Agencies</a>
        <a href="/companies/" class="text-xs text-text-dim hover:text-text-bright no-underline">Companies</a>
        <a href="/industries/" class="text-xs text-text-dim hover:text-text-bright no-underline">Industries</a>
      </div>
    </div>
  </nav>
  <div class="bg-bg flex items-center justify-center">
    <a href="#waitlist" class="bg-red border border-red-btn px-5 py-3.5 text-[10px] font-semibold uppercase tracking-[1.5px] text-text-bright no-underline hover:bg-red-btn transition-colors">
      Get Started
    </a>
  </div>
</header>
