        person_profiles: 'identified_only',
        capture_pageview: true,
        capture_pageleave: true,
      });
    </script>
  </head>
  <body class="bg-bg text-text font-body overflow-x-hidden leading-normal antialiased">
    <Header />
    <slot />
    <Footer />

    <!-- Sticky mobile CTA -->
    <div class="fixed bottom-0 left-0 right-0 bg-bg-raised border-t border-line z-50 px-4 py-3 md:hidden">
      <a
        href="#waitlist"
        class="block w-full text-center py-3 font-mono text-[10px] font-bold tracking-[2px] uppercase bg-red text-text-bright no-underline hover:bg-red-btn transition-colors"
      >
        Get Started →
      </a>
    </div>
  </body>
</html>
