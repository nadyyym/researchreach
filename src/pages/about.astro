---
import Base from "../layouts/Base.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import BottomCTA from "../components/BottomCTA.astro";
import "../styles/global.css";
---

<Base
  title="About — Sci-Buy"
  description="Sci-Buy is building research intelligence for those who sell to scientists. Learn about our mission, data philosophy, and team."
>
  <main>
    <Breadcrumb items={[{ name: "About", url: "/about/" }]} />

    <!-- HERO -->
    <section class="border-b border-line">
      <div class="px-6 py-16 md:px-12 md:py-24 max-w-4xl">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-6 block">About Sci-Buy</span>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-4 leading-[1.2]">
          We are building the<br />
          <strong class="font-semibold">research graph.</strong>
        </h1>
        <p class="text-[13px] text-text-dim leading-relaxed max-w-[480px]">
          The scientific workforce is one of the least-indexed professional populations on earth. Researchers publish constantly, win grants publicly, file patents -- and yet they are completely invisible to B2B tools.
        </p>
      </div>
    </section>

    <!-- PROBLEM + MOAT -->
    <section class="border-b border-line">
      <div class="grid grid-cols-1 md:grid-cols-2 grid-lines">
        <div class="bg-bg p-8 md:p-12">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-4 block">The Problem</span>
          <h2 class="text-lg font-light text-text-bright mb-3">
            Scientists are <strong class="font-semibold">invisible</strong> to sales tools
          </h2>
          <p class="text-[12px] text-text-dim leading-relaxed mb-4">
            A pharma BD team trying to reach the world's top CRISPR researchers has no reliable starting point. LinkedIn is wrong. ZoomInfo misses academics. Faculty directories are HTML tables with no emails.
          </p>
          <p class="text-[12px] text-text-dim leading-relaxed">
            We are aggregating the world's best open research infrastructure -- OpenAlex, ORCID, NIH Reporter, PubMed, Semantic Scholar -- and turning it into a contact intelligence layer that actually works for the scientific market.
          </p>
        </div>
        <div class="bg-bg p-8 md:p-12">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-4 block">Our Moat</span>
          <h2 class="text-lg font-light text-text-bright mb-3">
            Industry <strong class="font-semibold">bridge signals</strong>
          </h2>
          <p class="text-[12px] text-text-dim leading-relaxed mb-4">
            The most valuable researchers for B2B outreach are those with one foot in industry: patent holders, startup co-founders, SAB members, industry-funded PIs.
          </p>
          <p class="text-[12px] text-text-dim leading-relaxed">
            We built proprietary signal detection to surface exactly this population -- the researchers who bridge the gap between basic science and commercial application.
          </p>
        </div>
      </div>
    </section>

    <!-- DATA PHILOSOPHY -->
    <section class="border-b border-line">
      <div class="px-6 py-6 md:px-12 border-b border-line">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">Data Philosophy</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 grid-lines">
        <div class="bg-bg p-8 md:p-10 accent-top-red">
          <span class="font-mono text-[32px] text-line-accent block mb-4">01</span>
          <h3 class="text-[13px] font-semibold text-text-bright mb-2">Open sources only</h3>
          <p class="text-[12px] text-text-dim leading-relaxed">
            We only index publicly disclosed information: papers, grants, patents, public institutional pages. No scraping of private university systems.
          </p>
        </div>
        <div class="bg-bg p-8 md:p-10 accent-top-blue">
          <span class="font-mono text-[32px] text-line-accent block mb-4">02</span>
          <h3 class="text-[13px] font-semibold text-text-bright mb-2">Opt-out respected</h3>
          <p class="text-[12px] text-text-dim leading-relaxed">
            Any researcher can request removal. We maintain a global suppression list and honor it across all exports and API calls.
          </p>
        </div>
        <div class="bg-bg p-8 md:p-10 accent-top-yellow">
          <span class="font-mono text-[32px] text-line-accent block mb-4">03</span>
          <h3 class="text-[13px] font-semibold text-text-bright mb-2">Freshness first</h3>
          <p class="text-[12px] text-text-dim leading-relaxed">
            We would rather show fewer records with high confidence than pad the database with stale or unverified contacts.
          </p>
        </div>
      </div>
    </section>

    <!-- TEAM -->
    <section class="border-b border-line">
      <div class="px-6 py-6 md:px-12 border-b border-line">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">Team</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 grid-lines">
        <div class="bg-bg p-8 md:p-10">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-red mb-3 block">Co-founder, CEO</span>
          <p class="text-[12px] text-text-dim leading-relaxed">
            Former pharma BD. Spent years trying to reach researchers with broken tools. Built Sci-Buy to fix that.
          </p>
        </div>
        <div class="bg-bg p-8 md:p-10">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-accent mb-3 block">Co-founder, CTO</span>
          <p class="text-[12px] text-text-dim leading-relaxed">
            Previously at a large academic data aggregator. Built pipelines processing billions of research metadata records.
          </p>
        </div>
        <div class="bg-bg p-8 md:p-10">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-yellow mb-3 block">We are hiring</span>
          <p class="text-[12px] text-text-dim leading-relaxed">
            Looking for data engineers and researchers with experience in scientific graph construction. <a href="/contact/" class="text-accent hover:text-text-bright no-underline transition-colors">Get in touch.</a>
          </p>
        </div>
      </div>
    </section>

    <!-- BOTTOM CTA -->
    <BottomCTA />
  </main>
</Base>
