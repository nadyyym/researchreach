---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { datasetSchema, itemListSchema } from '../../lib/seo';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import '../../styles/global.css';

const entries = await getCollection('researchers');
const pageTitle = 'Top Academic Researchers — Sci-Buy';
const pageDesc = `Browse ${entries.length} leading academic researchers. Search by H-index, publications, grants, patents, and industry ties.`;

const extraSchemas = [
  datasetSchema({
    name: 'Researchers dataset — Sci-Buy',
    description: 'Profiled researchers indexed by Sci-Buy with H-index, publications, grants, patents, and industry ties.',
    url: '/researchers/',
    keywords: ['researchers', 'research intelligence', 'academic data'],
    variableMeasured: ['H-index', 'publications', 'grant count', 'patents', 'industry ties'],
    numberOfItems: entries.length,
  }),
  itemListSchema(
    'Researchers',
    entries.map((e) => ({
      name: (e.data as any).name || e.id,
      url: `/researchers/${e.id}/`,
      description: ((e.data as any).description || '').slice(0, 160),
    })),
  ),
];
---

<Base title={pageTitle} description={pageDesc} extraSchemas={extraSchemas}>
  <Breadcrumb items={[{ name: 'Researchers', url: '/researchers/' }]} />

  <!-- HERO -->
  <section class="border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] grid-lines">
      <div class="p-8 md:p-12">
        <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-4">RESEARCHER INDEX</p>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-3">
          Academic <strong class="font-semibold">Researchers</strong>
        </h1>
        <p class="text-[13px] text-text-dim leading-relaxed max-w-[520px]">
          Explore profiles of leading scientists. Each entry includes H-index, publication count,
          active grants, patents, and industry connections.
        </p>
      </div>
      <div class="p-8 md:p-12 flex items-center justify-center accent-top-blue">
        <div class="text-center">
          <p class="text-4xl font-light text-text-bright">{entries.length}</p>
          <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">RESEARCHERS</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID -->
  <section class="p-6 md:p-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 grid-lines">
      {entries.map((entry) => (
        <a
          href={`/researchers/${entry.id}/`}
          class="block p-6 hover:bg-bg-raised transition-colors no-underline group"
        >
          <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-3">
            {entry.data.institution}
          </p>
          <h2 class="text-[15px] font-semibold text-text-bright mb-1 group-hover:text-accent transition-colors">
            {entry.data.name}
          </h2>
          <p class="text-[12px] text-text-dim mb-3">{entry.data.field}</p>
          <div class="flex items-center gap-4 text-[11px] font-mono text-text-muted">
            <span>h-{entry.data.hindex}</span>
            <span>{entry.data.publications} pubs</span>
            <span>{entry.data.patents} patents</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <BottomCTA />
</Base>
