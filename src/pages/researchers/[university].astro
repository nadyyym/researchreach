---
import Base from "../../layouts/Base.astro";
import WaitlistForm from "../../components/WaitlistForm.astro";
import universities from "../../data/universities.json";

export function getStaticPaths() {
  return universities.map((uni) => ({
    params: { university: uni.slug },
    props: { uni },
  }));
}

const { uni } = Astro.props;

const {
  name,
  shortName,
  city,
  country,
  researcherCount,
  topDepartments,
  activeGrants,
  avgHIndex,
  useCase,
  useCaseType,
  description,
  type,
} = uni;

const pageTitle = `Find Researchers at ${name} — ResearchReach`;
const pageDesc = `Search ${researcherCount.toLocaleString()}+ researchers at ${name}. Filter by department, H-index, funding, and industry bridge signals. Export verified contacts.`;

// Related institutions: same country/type, exclude current
const related = universities
  .filter((u) => u.slug !== uni.slug && (u.country === country || u.type === type))
  .slice(0, 4);

const useCaseCallouts: Record<string, string> = {
  pharma:
    `${name} is a prime destination for pharma teams sourcing principal investigators, clinical trial collaborators, and drug discovery experts. Our data surfaces researchers by grant activity, publication velocity, and existing industry partnerships — so your BD team can reach the right PI before your competitors do.`,
  recruiting:
    `${name} produces some of the most in-demand research talent in the world. ResearchReach helps you identify researchers who are publication-active, grant-funded, and showing industry bridge signals like patent filings and company affiliations — before they update their LinkedIn.`,
  software:
    `${name}'s research community is a high-density market for scientific software adoption. Our contact intelligence lets you find lab PIs and department heads by methodology and tooling signals — so your sales team pitches the right buyer, not the IT department.`,
  vc:
    `${name} is a top source for VC deal flow — faculty spinouts, patent licensors, and industry advisors. ResearchReach surfaces researchers with commercialization signals: patent filings, SBIR grants, company affiliations, and conference keynotes that precede funding rounds.`,
};
---

<Base title={pageTitle} description={pageDesc}>
  <!-- ── NAV ── -->
  <header class="sticky top-0 z-40 bg-navy/95 backdrop-blur border-b border-navy-600">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-display text-lg font-bold text-white no-underline">
        Research<span class="text-electric">Reach</span>
      </a>
      <nav class="hidden md:flex items-center gap-6">
        <a href="/#how-it-works" class="text-slate-light hover:text-white text-sm no-underline transition-colors">How it works</a>
        <a href="/use-cases" class="text-slate-light hover:text-white text-sm no-underline transition-colors">Use cases</a>
        <a href="/researchers" class="text-electric text-sm no-underline font-medium">Browse Institutions</a>
        <a
          href="#waitlist"
          class="px-4 py-2 bg-electric text-white font-display text-sm font-bold tracking-wide uppercase rounded-lg no-underline hover:bg-electric-dim transition-colors"
        >
          Join Waitlist
        </a>
      </nav>
    </div>
  </header>

  <!-- ── BREADCRUMB ── -->
  <div class="bg-navy-800 border-b border-navy-600">
    <div class="max-w-6xl mx-auto px-6 py-3">
      <nav class="flex items-center gap-2 text-xs text-slate">
        <a href="/" class="hover:text-white no-underline transition-colors">Home</a>
        <span>›</span>
        <a href="/researchers" class="hover:text-white no-underline transition-colors">Researchers</a>
        <span>›</span>
        <span class="text-white">{shortName}</span>
      </nav>
    </div>
  </div>

  <!-- ── HERO ── -->
  <section class="bg-navy pt-16 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-700 border border-navy-500 mb-6">
        <span class="w-2 h-2 rounded-full bg-electric inline-block"></span>
        <span class="text-xs font-mono text-electric uppercase tracking-widest">{country} · {city}</span>
      </div>

      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 leading-tight">
        Find Researchers at<br /><span class="text-electric">{name}</span>
      </h1>
      <p class="text-slate-light text-lg md:text-xl max-w-2xl mb-10 leading-relaxed">
        {description}
      </p>

      <!-- Stat pills -->
      <div class="flex flex-wrap gap-3 mb-10">
        <div class="flex items-center gap-2 bg-navy-700 border border-navy-600 rounded-xl px-4 py-3">
          <span class="text-2xl font-display font-black text-white">{researcherCount.toLocaleString()}+</span>
          <span class="text-xs text-slate uppercase tracking-wide">Researchers</span>
        </div>
        <div class="flex items-center gap-2 bg-navy-700 border border-navy-600 rounded-xl px-4 py-3">
          <span class="text-2xl font-display font-black text-electric">{activeGrants.toLocaleString()}</span>
          <span class="text-xs text-slate uppercase tracking-wide">Active Grants</span>
        </div>
        <div class="flex items-center gap-2 bg-navy-700 border border-navy-600 rounded-xl px-4 py-3">
          <span class="text-2xl font-display font-black text-white">{topDepartments[0]}</span>
          <span class="text-xs text-slate uppercase tracking-wide">Top Dept</span>
        </div>
        <div class="flex items-center gap-2 bg-navy-700 border border-navy-600 rounded-xl px-4 py-3">
          <span class="text-2xl font-display font-black text-electric">h{avgHIndex}</span>
          <span class="text-xs text-slate uppercase tracking-wide">Avg H-index</span>
        </div>
      </div>

      <a
        href="#waitlist"
        class="inline-flex items-center gap-2 px-8 py-4 bg-electric text-white font-display font-bold text-base tracking-wide uppercase rounded-xl no-underline hover:bg-electric-dim transition-colors"
      >
        Get Access to {shortName} Data →
      </a>
    </div>
  </section>

  <!-- ── TOP DEPARTMENTS ── -->
  <section class="bg-navy-800 border-y border-navy-600 py-14 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-2xl font-bold text-white mb-2">Top Research Departments</h2>
      <p class="text-slate text-sm mb-8">Filter researchers by department to find the exact expertise you need.</p>
      <div class="flex flex-wrap gap-3">
        {topDepartments.map((dept) => (
          <span class="px-4 py-2 bg-navy-700 border border-navy-500 text-slate-light text-sm rounded-full font-medium cursor-default hover:border-electric hover:text-white transition-colors">
            {dept}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── USE CASE CALLOUT ── -->
  <section class="bg-navy py-14 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block px-3 py-1 rounded-full bg-electric/10 border border-electric/30 text-electric text-xs font-mono uppercase tracking-widest mb-4">
            {useCaseType === "pharma" ? "🧪 Pharma & Biotech" :
             useCaseType === "recruiting" ? "🎯 Talent Acquisition" :
             useCaseType === "software" ? "💻 Research Software" :
             "💡 Venture Capital"}
          </div>
          <h2 class="font-display text-3xl font-bold text-white mb-4">Why teams use {shortName} data</h2>
          <p class="text-slate-light text-base leading-relaxed">
            {useCaseCallouts[useCaseType]}
          </p>
          <div class="mt-6 flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-electric/20 flex items-center justify-center">
              <span class="text-electric text-sm">✓</span>
            </div>
            <span class="text-slate text-sm">Filter by H-index, grant type, industry affiliation</span>
          </div>
          <div class="mt-3 flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-electric/20 flex items-center justify-center">
              <span class="text-electric text-sm">✓</span>
            </div>
            <span class="text-slate text-sm">Export verified emails and LinkedIn profiles</span>
          </div>
          <div class="mt-3 flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-electric/20 flex items-center justify-center">
              <span class="text-electric text-sm">✓</span>
            </div>
            <span class="text-slate text-sm">Track industry bridge signals: patents, consulting, SABs</span>
          </div>
        </div>

        <!-- Sample researcher card -->
        <div class="relative">
          <div class="bg-navy-700 border border-navy-500 rounded-2xl p-6 relative overflow-hidden">
            <!-- Blurred/locked overlay -->
            <div class="absolute inset-0 bg-navy-700/80 backdrop-blur-sm z-10 flex flex-col items-center justify-center rounded-2xl">
              <div class="text-3xl mb-3">🔒</div>
              <p class="text-white font-display font-bold text-sm text-center">Join waitlist to unlock</p>
              <p class="text-slate text-xs mt-1 text-center max-w-xs">Access full profiles with verified contacts</p>
              <a href="#waitlist" class="mt-4 px-5 py-2 bg-electric text-white text-xs font-bold uppercase tracking-wide rounded-lg no-underline hover:bg-electric-dim transition-colors">
                Get Access →
              </a>
            </div>

            <!-- Fake researcher card (visible behind blur) -->
            <div class="flex items-start gap-4 mb-4">
              <div class="w-12 h-12 rounded-full bg-navy-600 border border-navy-500 flex items-center justify-center text-slate font-bold text-lg flex-shrink-0">
                JD
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-white font-semibold text-sm">John D. ██████████</h3>
                </div>
                <p class="text-slate text-xs">Associate Professor · {topDepartments[0]}</p>
                <p class="text-slate text-xs">{name}</p>
              </div>
            </div>

            <div class="flex flex-wrap gap-2 mb-4">
              <span class="px-2 py-1 bg-electric/20 text-electric text-xs rounded font-mono">h-index: {Math.floor(avgHIndex * 0.9)}</span>
              <span class="px-2 py-1 bg-green-900/40 text-green-400 text-xs rounded font-mono">4 active grants</span>
              <span class="px-2 py-1 bg-purple-900/40 text-purple-400 text-xs rounded">Industry bridge: Patent holder</span>
            </div>

            <div class="border-t border-navy-600 pt-4 grid grid-cols-2 gap-3">
              <div>
                <p class="text-xs text-slate mb-1">Total citations</p>
                <p class="text-white font-mono text-sm">██,███</p>
              </div>
              <div>
                <p class="text-xs text-slate mb-1">Email</p>
                <p class="text-white font-mono text-sm blur-sm select-none">j.d████@{shortName.toLowerCase().replace(/ /g, '')}.edu</p>
              </div>
              <div>
                <p class="text-xs text-slate mb-1">Last publication</p>
                <p class="text-white font-mono text-sm">2025</p>
              </div>
              <div>
                <p class="text-xs text-slate mb-1">LinkedIn</p>
                <p class="text-electric font-mono text-sm blur-sm select-none">linkedin.com/in/██████</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WAITLIST FORM ── -->
  <section id="waitlist" class="bg-navy-800 py-20 px-6 border-t border-navy-600">
    <div class="max-w-xl mx-auto">
      <WaitlistForm
        heading={`Get access to ${shortName} researcher data`}
        subheading={`Join the waitlist to search ${researcherCount.toLocaleString()}+ ${shortName} researchers by department, funding, and industry bridge signals.`}
      />
    </div>
  </section>

  <!-- ── RELATED INSTITUTIONS ── -->
  {related.length > 0 && (
    <section class="bg-navy py-16 px-6 border-t border-navy-600">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-2xl font-bold text-white mb-2">Related Institutions</h2>
        <p class="text-slate text-sm mb-8">Explore researcher databases at similar institutions.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {related.map((r) => (
            <a
              href={`/researchers/${r.slug}`}
              class="block bg-navy-700 border border-navy-600 rounded-xl p-5 no-underline hover:border-electric transition-colors group"
            >
              <div class="flex items-start justify-between mb-3">
                <span class="text-xs font-mono text-slate uppercase">{r.country}</span>
                <span class="text-xs text-electric opacity-0 group-hover:opacity-100 transition-opacity">→</span>
              </div>
              <h3 class="text-white font-semibold text-sm mb-1 group-hover:text-electric transition-colors">{r.shortName}</h3>
              <p class="text-slate text-xs mb-3 leading-relaxed line-clamp-2">{r.name}</p>
              <div class="flex items-center gap-2">
                <span class="text-xs font-mono text-electric">{r.researcherCount.toLocaleString()}+</span>
                <span class="text-xs text-slate">researchers</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>
