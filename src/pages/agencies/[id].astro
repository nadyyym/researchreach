---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const entries = await getCollection('agencies');
  const countries = await getCollection('countries');
  const researchers = await getCollection('researchers');

  // Country slug map: try slug, full name lowercase, and short forms (e.g. "us" / "united states").
  const countryByKey = new Map<string, string>();
  for (const c of countries) {
    countryByKey.set(c.id, c.id);
    countryByKey.set(c.data.name.toLowerCase(), c.id);
  }

  return entries.map((entry) => {
    const countryKey = entry.data.country.toLowerCase();
    const countrySlug =
      countryByKey.get(countryKey) ??
      // Fallbacks for "United States" → us, "United Kingdom" → uk
      (countryKey === 'united states' ? 'us' : null) ??
      (countryKey === 'united kingdom' ? 'uk' : null) ??
      null;

    // Researchers whose industryTies mention this agency name (case-insensitive substring).
    const matchingResearchers = researchers
      .filter((r) =>
        r.data.industryTies.some(
          (tie) => tie.toLowerCase().includes(entry.data.name.toLowerCase().split(' (')[0]),
        ),
      )
      .slice(0, 6);

    return {
      params: { id: entry.id },
      props: { entry, countrySlug, matchingResearchers },
    };
  });
}

const { entry, countrySlug, matchingResearchers } = Astro.props;
const d = entry.data;

const pageTitle = `${d.name} — Funding Agency — Sci-Buy`;
const pageDesc = `${d.name}: ${d.type} funding agency in ${d.country}. Budget: ${d.budget}. ${d.programs.length} programs. Find researchers funded by ${d.name}.`;
---

<Base title={pageTitle} description={pageDesc}>
  <Breadcrumb items={[
    { name: 'Agencies', url: '/agencies/' },
    { name: d.name, url: `/agencies/${entry.id}/` },
  ]} />

  <!-- HERO -->
  <section class="border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] grid-lines">
      <div class="p-8 md:p-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted">{d.type.toUpperCase()}</span>
          <span class="w-px h-3 bg-line-accent"></span>
          {countrySlug ? (
            <a href={`/countries/${countrySlug}/`} class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted hover:text-text-bright transition-colors no-underline">{d.country}</a>
          ) : (
            <span class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted">{d.country}</span>
          )}
        </div>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-3">
          {d.name}
        </h1>
        <p class="text-[13px] text-text leading-relaxed max-w-[520px]">
          {d.description}
        </p>
      </div>
      <div class="p-8 md:p-12 accent-top-blue">
        <div class="space-y-6">
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">BUDGET</p>
            <p class="text-2xl font-light text-text-bright">{d.budget}</p>
          </div>
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">TYPE</p>
            <p class="text-lg font-light text-text-bright capitalize">{d.type}</p>
          </div>
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">COUNTRY</p>
            {countrySlug ? (
              <a href={`/countries/${countrySlug}/`} class="text-lg font-light text-text-bright hover:text-accent transition-colors no-underline">{d.country}</a>
            ) : (
              <p class="text-lg font-light text-text-bright">{d.country}</p>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAMS -->
  <section class="border-b border-line p-8 md:p-12">
    <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">PROGRAMS</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-line">
      {d.programs.map((program, i) => (
        <div class="bg-bg p-4 flex items-center gap-4">
          <span class="font-mono text-[10px] text-text-muted w-6 flex-shrink-0">{String(i + 1).padStart(2, '0')}</span>
          <p class="text-[13px] text-text">{program}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- TERMINAL -->
  <section class="border-b border-line p-8 md:p-12">
    <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">TRY IT</p>
    <TerminalMockup
      lines={[
        { type: 'prompt', text: `sci-buy search --funder "${d.name}"` },
        { type: 'blank', text: '' },
        { type: 'output', text: `Searching researchers funded by ${d.name}...` },
        { type: 'success', text: `Found grants across ${d.programs.length} programs` },
        { type: 'output', text: `Budget: ${d.budget} | Country: ${d.country} | Type: ${d.type}` },
      ]}
    />
  </section>

  {matchingResearchers.length > 0 && (
    <section class="border-b border-line p-8 md:p-12">
      <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">Researchers funded by {d.name.split(' (')[0]}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-line">
        {matchingResearchers.map((r) => (
          <a href={`/researchers/${r.id}/`} class="bg-bg p-4 no-underline group hover:bg-bg-raised transition-colors">
            <p class="text-[13px] text-text-bright group-hover:text-accent transition-colors">{r.data.name}</p>
            <p class="font-mono text-[10px] text-text-muted mt-1">{r.data.field} · H-index {r.data.hindex}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <BottomCTA />
</Base>
