---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import '../../styles/global.css';

const entries = await getCollection('agencies');
const pageTitle = 'Funding Agencies — Sci-Buy';
const pageDesc = `Browse ${entries.length} research funding agencies. Explore government, private, and foundation funders by country, budget, and programs.`;
---

<Base title={pageTitle} description={pageDesc}>
  <Breadcrumb items={[{ name: 'Agencies', url: '/agencies/' }]} />

  <!-- HERO -->
  <section class="border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] grid-lines">
      <div class="p-8 md:p-12">
        <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-4">FUNDER INDEX</p>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-3">
          Funding <strong class="font-semibold">Agencies</strong>
        </h1>
        <p class="text-[13px] text-text-dim leading-relaxed max-w-[520px]">
          Explore research funding organizations worldwide. Each profile includes budget,
          program areas, country of origin, and agency type.
        </p>
      </div>
      <div class="p-8 md:p-12 flex items-center justify-center accent-top-blue">
        <div class="text-center">
          <p class="text-4xl font-light text-text-bright">{entries.length}</p>
          <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">AGENCIES</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID -->
  <section class="p-6 md:p-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 grid-lines">
      {entries.map((entry) => (
        <a
          href={`/agencies/${entry.id}/`}
          class="block p-6 hover:bg-bg-raised transition-colors no-underline group"
        >
          <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">{entry.data.country}</span>
            <span class="w-px h-3 bg-line-accent"></span>
            <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">{entry.data.type}</span>
          </div>
          <h2 class="text-[15px] font-semibold text-text-bright mb-2 group-hover:text-accent transition-colors">
            {entry.data.name}
          </h2>
          <p class="text-[12px] text-text-dim leading-relaxed line-clamp-2 mb-4">
            {entry.data.description}
          </p>
          <div class="flex items-center gap-4 text-[11px] font-mono text-text-muted">
            <span>{entry.data.budget}</span>
            <span>{entry.data.programs.length} programs</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <BottomCTA />
</Base>
