---
import Base from "../layouts/Base.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import TerminalMockup from "../components/TerminalMockup.astro";
import BottomCTA from "../components/BottomCTA.astro";
import "../styles/global.css";

const sampleResponse = {
  "id": "orcid:0000-0002-1234-5678",
  "name": "Dr. Sarah Chen",
  "email": "s.chen@stanford.edu",
  "email_confidence": "high",
  "institution": "Stanford University",
  "department": "Department of Chemical Engineering",
  "position": "Associate Professor",
  "h_index": 32,
  "citation_count": 4821,
  "publication_count": 67,
  "recent_publications": [
    {
      "title": "CRISPR-based gene regulation in mammalian cells",
      "doi": "10.1038/s41587-024-01234-5",
      "year": 2024,
      "journal": "Nature Biotechnology"
    }
  ],
  "grants": [
    {
      "source": "NIH",
      "type": "R01",
      "title": "Precision genome editing for therapeutic applications",
      "amount_usd": 2100000,
      "active": true,
      "end_date": "2027-06-30"
    }
  ],
  "industry_signals": {
    "patent_count": 4,
    "startup_affiliations": ["CRISPRx Bio (SAB)"],
    "industry_funding": true,
    "industry_coauthorships": 12
  },
  "last_updated": "2026-04-01T00:00:00Z"
};

const endpoints = [
  { method: "GET", path: "/v1/researchers/search", desc: "Search the researcher graph by field, institution, grant type, H-index range, and industry signals. Returns paginated results." },
  { method: "GET", path: "/v1/researchers/{id}", desc: "Retrieve a full researcher profile by ORCID, Sci-Buy ID, or email. Includes contact data, publication metrics, and funding." },
  { method: "POST", path: "/v1/lists/export", desc: "Bulk export a list of researcher profiles. Accepts a list of IDs or a search query. Returns CSV or JSON payload." },
  { method: "GET", path: "/v1/grants/search", desc: "Search active NIH and NSF grants by PI, institution, keyword, or funding amount. Useful for intent-based targeting." },
];
---

<Base
  title="Developers API — Sci-Buy"
  description="Sci-Buy REST API for programmatic access to the research graph. Integrate researcher contact intelligence into your CRM, data pipeline, or application."
>
  <main>
    <Breadcrumb items={[{ name: "Developers", url: "/developers" }]} />

    <!-- HERO -->
    <section class="border-b border-line">
      <div class="px-6 py-16 md:px-12 md:py-24 max-w-4xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">API v1</span>
          <span class="w-px h-3 bg-line-accent"></span>
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-accent">Early Access</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-4 leading-[1.2]">
          Sci-Buy <strong class="font-semibold">REST API</strong>
        </h1>
        <p class="text-[13px] text-text-dim leading-relaxed max-w-[480px]">
          Programmatic access to the research graph. Build contact intelligence into your CRM, data pipeline, or scientific application.
        </p>
      </div>
    </section>

    <!-- SAMPLE RESPONSE -->
    <section class="border-b border-line">
      <div class="px-6 py-6 md:px-12 border-b border-line">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">Sample Response</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] grid-lines">
        <div class="bg-bg p-8 md:p-12">
          <h2 class="text-lg font-light text-text-bright mb-3">
            <strong class="font-semibold">Researcher</strong> record
          </h2>
          <p class="text-[12px] text-text-dim leading-relaxed mb-4">
            A single researcher record contains identity, contact, publication metrics, funding, and industry bridge signals.
          </p>
          <div class="space-y-2.5">
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Verified email with confidence score</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">H-index, citations, publication count</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Active grants with amounts and dates</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Industry bridge signals (patents, startups)</p>
            </div>
          </div>
        </div>
        <div class="bg-bg p-6 md:p-8">
          <div class="bg-bg-raised border border-line overflow-hidden">
            <div class="flex items-center gap-3 px-4 py-2.5 border-b border-line">
              <span class="font-mono text-[10px] text-text-muted">GET /v1/researchers/{"{id}"}</span>
            </div>
            <pre class="p-4 text-[11px] font-mono text-text-dim overflow-x-auto leading-relaxed whitespace-pre-wrap">{JSON.stringify(sampleResponse, null, 2)}</pre>
          </div>
        </div>
      </div>
    </section>

    <!-- ENDPOINTS -->
    <section class="border-b border-line">
      <div class="px-6 py-6 md:px-12 border-b border-line">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">Core Endpoints</span>
      </div>
      <div class="space-y-0">
        {endpoints.map((ep, i) => (
          <div class:list={['px-6 py-6 md:px-12 flex flex-col md:flex-row md:items-start gap-4', i < endpoints.length - 1 ? 'border-b border-line' : '']}>
            <div class="flex items-center gap-3 shrink-0 md:w-[280px]">
              <span class:list={[
                'font-mono text-[10px] px-2 py-0.5 border',
                ep.method === 'GET' ? 'text-accent border-accent-dim' : 'text-yellow border-yellow-dim'
              ]}>
                {ep.method}
              </span>
              <code class="font-mono text-[12px] text-text">{ep.path}</code>
            </div>
            <p class="text-[12px] text-text-dim leading-relaxed">{ep.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- SDK -->
    <section class="border-b border-line">
      <div class="px-6 py-6 md:px-12 border-b border-line">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">SDKs & Integration</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 grid-lines">
        <div class="bg-bg p-8">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-red mb-3 block">Python</span>
          <div class="bg-bg-raised border border-line p-3 font-mono text-[11px] text-text-dim">
            pip install sci-buy
          </div>
          <p class="text-[11px] text-text-muted mt-2">Coming at launch</p>
        </div>
        <div class="bg-bg p-8">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-accent mb-3 block">Node.js</span>
          <div class="bg-bg-raised border border-line p-3 font-mono text-[11px] text-text-dim">
            npm install @sci-buy/sdk
          </div>
          <p class="text-[11px] text-text-muted mt-2">Coming at launch</p>
        </div>
        <div class="bg-bg p-8">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-yellow mb-3 block">REST API</span>
          <div class="bg-bg-raised border border-line p-3 font-mono text-[11px] text-text-dim">
            curl api.selltoscientists.com/v1
          </div>
          <p class="text-[11px] text-text-muted mt-2">Available now in early access</p>
        </div>
      </div>
    </section>

    <!-- BOTTOM CTA -->
    <BottomCTA />
  </main>
</Base>
