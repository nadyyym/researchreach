---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import { entityOrgSchema } from '../../lib/seo';
import '../../styles/global.css';

export async function getStaticPaths() {
  const entries = await getCollection('companies');
  const industries = await getCollection('industries');
  const researchers = await getCollection('researchers');

  // Build industry slug map: try slug, name, and first-word lowercase forms.
  const industryByKey = new Map<string, string>();
  for (const ind of industries) {
    const slug = ind.id;
    const name = ind.data.name.toLowerCase();
    industryByKey.set(slug, slug);
    industryByKey.set(name, slug);
    industryByKey.set(name.split(' ')[0], slug);
  }

  return entries.map((entry) => {
    const industryKey = entry.data.industry.toLowerCase();
    const industrySlug =
      industryByKey.get(industryKey) ??
      industryByKey.get(industryKey.split(' ')[0]) ??
      null;

    // Researchers whose industryTies includes this company's name (case-insensitive substring).
    const matchingResearchers = researchers
      .filter((r) =>
        r.data.industryTies.some(
          (tie) => tie.toLowerCase().includes(entry.data.name.toLowerCase()),
        ),
      )
      .slice(0, 6);

    return {
      params: { id: entry.id },
      props: { entry, industrySlug, matchingResearchers },
    };
  });
}

const { entry, industrySlug, matchingResearchers } = Astro.props;
const d = entry.data;

const pageTitle = `${d.name} — Academic Collaborations & R&D — Sci-Buy`;
const pageDesc = `${d.name} in ${d.industry}. R&D spend: ${d.rdSpend}. ${d.academicCollabs} academic collaborations, ${d.patents} patents. Find researchers connected to ${d.name}.`;

const extraSchemas = [
  entityOrgSchema({
    type: 'Corporation',
    name: d.name,
    description: d.description,
  }),
];
---

<Base title={pageTitle} description={pageDesc} extraSchemas={extraSchemas}>
  <Breadcrumb items={[
    { name: 'Companies', url: '/companies/' },
    { name: d.name, url: `/companies/${entry.id}/` },
  ]} />

  <!-- HERO -->
  <section class="border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] grid-lines">
      <div class="p-8 md:p-12">
        <div class="flex items-center gap-3 mb-4">
          {industrySlug ? (
            <a href={`/industries/${industrySlug}/`} class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted hover:text-text-bright transition-colors no-underline">{d.industry}</a>
          ) : (
            <span class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted">{d.industry}</span>
          )}
        </div>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-3">
          {d.name}
        </h1>
        <p class="text-[13px] text-text leading-relaxed max-w-[520px]">
          {d.description}
        </p>
      </div>
      <div class="p-8 md:p-12 accent-top-yellow">
        <div class="space-y-6">
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">R&D SPEND</p>
            <p class="text-2xl font-light text-text-bright">{d.rdSpend}</p>
          </div>
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">INDUSTRY</p>
            {industrySlug ? (
              <a href={`/industries/${industrySlug}/`} class="text-lg font-light text-text-bright hover:text-accent transition-colors no-underline">{d.industry}</a>
            ) : (
              <p class="text-lg font-light text-text-bright">{d.industry}</p>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS GRID -->
  <section class="border-b border-line">
    <div class="grid grid-cols-2 grid-lines">
      <div class="p-6 text-center accent-top-red">
        <p class="text-2xl font-light text-text-bright">{d.academicCollabs}</p>
        <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">ACADEMIC COLLABORATIONS</p>
      </div>
      <div class="p-6 text-center accent-top-blue">
        <p class="text-2xl font-light text-text-bright">{d.patents}</p>
        <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">PATENTS</p>
      </div>
    </div>
  </section>

  <!-- TERMINAL -->
  <section class="border-b border-line p-8 md:p-12">
    <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">TRY IT</p>
    <TerminalMockup
      lines={[
        { type: 'prompt', text: `sci-buy search --collaborator "${d.name}"` },
        { type: 'blank', text: '' },
        { type: 'output', text: `Searching researchers collaborating with ${d.name}...` },
        { type: 'success', text: `Found ${d.academicCollabs} academic collaborations` },
        { type: 'output', text: `Industry: ${d.industry} | R&D: ${d.rdSpend} | Patents: ${d.patents}` },
      ]}
    />
  </section>

  {matchingResearchers.length > 0 && (
    <section class="border-b border-line p-8 md:p-12">
      <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">Researchers connected to {d.name}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-line">
        {matchingResearchers.map((r) => (
          <a href={`/researchers/${r.id}/`} class="bg-bg p-4 no-underline group hover:bg-bg-raised transition-colors">
            <p class="text-[13px] text-text-bright group-hover:text-accent transition-colors">{r.data.name}</p>
            <p class="font-mono text-[10px] text-text-muted mt-1">{r.data.field} · H-index {r.data.hindex}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <BottomCTA />
</Base>
