---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const entries = await getCollection('companies');
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;

const pageTitle = `${d.name} — Academic Collaborations & R&D — Sci-Buy`;
const pageDesc = `${d.name} in ${d.industry}. R&D spend: ${d.rdSpend}. ${d.academicCollabs} academic collaborations, ${d.patents} patents. Find researchers connected to ${d.name}.`;
---

<Base title={pageTitle} description={pageDesc}>
  <Breadcrumb items={[
    { name: 'Companies', url: '/companies/' },
    { name: d.name, url: `/companies/${entry.id}/` },
  ]} />

  <!-- HERO -->
  <section class="border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] grid-lines">
      <div class="p-8 md:p-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted">{d.industry}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-3">
          {d.name}
        </h1>
        <p class="text-[13px] text-text leading-relaxed max-w-[520px]">
          {d.description}
        </p>
      </div>
      <div class="p-8 md:p-12 accent-top-yellow">
        <div class="space-y-6">
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">R&D SPEND</p>
            <p class="text-2xl font-light text-text-bright">{d.rdSpend}</p>
          </div>
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">INDUSTRY</p>
            <p class="text-lg font-light text-text-bright">{d.industry}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS GRID -->
  <section class="border-b border-line">
    <div class="grid grid-cols-2 grid-lines">
      <div class="p-6 text-center accent-top-red">
        <p class="text-2xl font-light text-text-bright">{d.academicCollabs}</p>
        <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">ACADEMIC COLLABORATIONS</p>
      </div>
      <div class="p-6 text-center accent-top-blue">
        <p class="text-2xl font-light text-text-bright">{d.patents}</p>
        <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">PATENTS</p>
      </div>
    </div>
  </section>

  <!-- TERMINAL -->
  <section class="border-b border-line p-8 md:p-12">
    <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">TRY IT</p>
    <TerminalMockup
      lines={[
        { type: 'prompt', text: `sci-buy search --collaborator "${d.name}"` },
        { type: 'blank', text: '' },
        { type: 'output', text: `Searching researchers collaborating with ${d.name}...` },
        { type: 'success', text: `Found ${d.academicCollabs} academic collaborations` },
        { type: 'output', text: `Industry: ${d.industry} | R&D: ${d.rdSpend} | Patents: ${d.patents}` },
      ]}
    />
  </section>

  <BottomCTA />
</Base>
