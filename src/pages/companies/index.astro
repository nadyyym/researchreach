---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { datasetSchema, itemListSchema, breadcrumbSchema } from '../../lib/seo';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import '../../styles/global.css';

const entries = await getCollection('companies');
const pageTitle = 'Companies with Academic Collaborations — Sci-Buy';
const pageDesc = `Browse ${entries.length} companies with active academic research partnerships. Search by industry, R&D spend, patents, and collaboration count.`;

const extraSchemas = [
  datasetSchema({
    name: 'Companies dataset — Sci-Buy',
    description: 'Companies with academic R&D collaborations indexed by Sci-Buy.',
    url: '/companies/',
    keywords: ['companies', 'research intelligence', 'academic data'],
    variableMeasured: ['industry', 'R&D spend', 'academic collaborations', 'patents'],
    numberOfItems: entries.length,
  }),
  itemListSchema(
    'Companies',
    entries.map((e) => ({
      name: (e.data as any).name || e.id,
      url: `/companies/${e.id}/`,
      description: ((e.data as any).description || '').slice(0, 160),
    })),
  ),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Companies', url: '/companies/' },
  ]),
];
---

<Base title={pageTitle} description={pageDesc} extraSchemas={extraSchemas}>
  <Breadcrumb items={[{ name: 'Companies', url: '/companies/' }]} />

  <!-- HERO -->
  <section class="border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] grid-lines">
      <div class="p-8 md:p-12">
        <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-4">COMPANY INDEX</p>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-3">
          Industry <strong class="font-semibold">Companies</strong>
        </h1>
        <p class="text-[13px] text-text-dim leading-relaxed max-w-[520px]">
          Explore companies with active academic research collaborations. Each profile includes
          industry, R&D spending, patent count, and number of academic partnerships.
        </p>
      </div>
      <div class="p-8 md:p-12 flex items-center justify-center accent-top-yellow">
        <div class="text-center">
          <p class="text-4xl font-light text-text-bright">{entries.length}</p>
          <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">COMPANIES</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID -->
  <section class="p-6 md:p-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 grid-lines">
      {entries.map((entry) => (
        <a
          href={`/companies/${entry.id}/`}
          class="block p-6 hover:bg-bg-raised transition-colors no-underline group"
        >
          <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-3">
            {entry.data.industry}
          </p>
          <h2 class="text-[15px] font-semibold text-text-bright mb-2 group-hover:text-accent transition-colors">
            {entry.data.name}
          </h2>
          <p class="text-[12px] text-text-dim leading-relaxed line-clamp-2 mb-4">
            {entry.data.description}
          </p>
          <div class="flex items-center gap-4 text-[11px] font-mono text-text-muted">
            <span>R&D: {entry.data.rdSpend}</span>
            <span>{entry.data.patents} patents</span>
            <span>{entry.data.academicCollabs} collabs</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <BottomCTA />
</Base>
