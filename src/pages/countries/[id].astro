---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const entries = await getCollection('countries');
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;

const pageTitle = `${d.name} — Research Output & Institutions — Sci-Buy`;
const pageDesc = `${d.name} research intelligence: ${d.researchOutput.toLocaleString()} papers, ${d.topInstitutions.length} top institutions, ${d.topAgencies.length} funding agencies. Top fields: ${d.topFields.slice(0, 3).join(', ')}.`;

const flagCodePoints = [...d.code.toUpperCase()].map(
  (c) => 0x1f1e6 + c.charCodeAt(0) - 65
);
const flag = String.fromCodePoint(...flagCodePoints);
---

<Base title={pageTitle} description={pageDesc}>
  <Breadcrumb items={[
    { name: 'Countries', url: '/countries/' },
    { name: d.name, url: `/countries/${entry.id}/` },
  ]} />

  <!-- HERO -->
  <section class="border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] grid-lines">
      <div class="p-8 md:p-12">
        <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-4">COUNTRY PROFILE</p>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-3">
          <span class="mr-3">{flag}</span>{d.name}
        </h1>
        <p class="text-[13px] text-text leading-relaxed max-w-[520px]">
          {d.description}
        </p>
      </div>
      <div class="p-8 md:p-12 accent-top-red">
        <div class="space-y-6">
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">RESEARCH OUTPUT</p>
            <p class="text-2xl font-light text-text-bright">{d.researchOutput.toLocaleString()}</p>
          </div>
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">INSTITUTIONS</p>
            <p class="text-2xl font-light text-text-bright">{d.topInstitutions.length}</p>
          </div>
          <div>
            <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-1">FUNDING AGENCIES</p>
            <p class="text-2xl font-light text-text-bright">{d.topAgencies.length}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS GRID -->
  <section class="border-b border-line">
    <div class="grid grid-cols-3 grid-lines">
      <div class="p-6 text-center accent-top-blue">
        <p class="text-2xl font-light text-text-bright">{d.researchOutput.toLocaleString()}</p>
        <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">PAPERS</p>
      </div>
      <div class="p-6 text-center accent-top-yellow">
        <p class="text-2xl font-light text-text-bright">{d.topInstitutions.length}</p>
        <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">INSTITUTIONS</p>
      </div>
      <div class="p-6 text-center accent-top-red">
        <p class="text-2xl font-light text-text-bright">{d.topAgencies.length}</p>
        <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">AGENCIES</p>
      </div>
    </div>
  </section>

  <!-- TOP INSTITUTIONS -->
  <section class="border-b border-line p-8 md:p-12">
    <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">TOP INSTITUTIONS</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-line">
      {d.topInstitutions.map((inst) => (
        <div class="bg-bg p-4">
          <p class="text-[13px] text-text">{inst}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- TOP FIELDS -->
  <section class="border-b border-line p-8 md:p-12">
    <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">TOP RESEARCH FIELDS</p>
    <div class="flex flex-wrap gap-2">
      {d.topFields.map((field) => (
        <span class="px-3 py-1.5 bg-bg-raised border border-line text-[12px] text-text font-mono">
          {field}
        </span>
      ))}
    </div>
  </section>

  <!-- FUNDING AGENCIES -->
  <section class="border-b border-line p-8 md:p-12">
    <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">FUNDING AGENCIES</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-line">
      {d.topAgencies.map((agency) => (
        <div class="bg-bg p-4">
          <p class="text-[13px] text-text">{agency}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- TERMINAL -->
  <section class="border-b border-line p-8 md:p-12">
    <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-6">TRY IT</p>
    <TerminalMockup
      lines={[
        { type: 'prompt', text: `sci-buy search --country "${d.name}"` },
        { type: 'blank', text: '' },
        { type: 'output', text: `Searching researchers in ${d.name}...` },
        { type: 'success', text: `${d.researchOutput.toLocaleString()} papers indexed across ${d.topInstitutions.length} institutions` },
        { type: 'output', text: `Top field: ${d.topFields[0]} | ${d.topAgencies.length} funding agencies` },
      ]}
    />
  </section>

  <BottomCTA />
</Base>
