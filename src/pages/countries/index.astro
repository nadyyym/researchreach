---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { datasetSchema, itemListSchema, breadcrumbSchema } from '../../lib/seo';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import '../../styles/global.css';

const entries = await getCollection('countries');
const pageTitle = 'Research by Country — Sci-Buy';
const pageDesc = `Explore research output across ${entries.length} countries. Browse top institutions, funding agencies, and leading fields by nation.`;

const extraSchemas = [
  datasetSchema({
    name: 'Countries dataset — Sci-Buy',
    description: 'Country-level research output indexed by Sci-Buy with top institutions and funding agencies.',
    url: '/countries/',
    keywords: ['countries', 'research intelligence', 'academic data'],
    variableMeasured: ['research output', 'top fields', 'top institutions', 'top agencies'],
    numberOfItems: entries.length,
  }),
  itemListSchema(
    'Countries',
    entries.map((e) => ({
      name: (e.data as any).name || e.id,
      url: `/countries/${e.id}/`,
      description: ((e.data as any).description || '').slice(0, 160),
    })),
  ),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Countries', url: '/countries/' },
  ]),
];
---

<Base title={pageTitle} description={pageDesc} extraSchemas={extraSchemas}>
  <Breadcrumb items={[{ name: 'Countries', url: '/countries/' }]} />

  <!-- HERO -->
  <section class="border-b border-line">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] grid-lines">
      <div class="p-8 md:p-12">
        <p class="font-mono text-[9px] tracking-[3px] uppercase text-text-muted mb-4">COUNTRY INDEX</p>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-3">
          Research by <strong class="font-semibold">Country</strong>
        </h1>
        <p class="text-[13px] text-text-dim leading-relaxed max-w-[520px]">
          Explore scientific research output by nation. Each country profile includes top institutions,
          funding agencies, leading research fields, and total research output.
        </p>
      </div>
      <div class="p-8 md:p-12 flex items-center justify-center accent-top-red">
        <div class="text-center">
          <p class="text-4xl font-light text-text-bright">{entries.length}</p>
          <p class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mt-1">COUNTRIES</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID -->
  <section class="p-6 md:p-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 grid-lines">
      {entries.map((entry) => (
        <a
          href={`/countries/${entry.id}/`}
          class="block p-6 hover:bg-bg-raised transition-colors no-underline group"
        >
          <h2 class="text-[15px] font-semibold text-text-bright mb-2 group-hover:text-accent transition-colors">
            <span class="mr-2">{String.fromCodePoint(...[...entry.data.code.toUpperCase()].map(c => 0x1f1e6 + c.charCodeAt(0) - 65))}</span>{entry.data.name}
          </h2>
          <p class="text-[12px] text-text-dim leading-relaxed line-clamp-2 mb-4">
            {entry.data.description}
          </p>
          <div class="flex items-center gap-4 text-[11px] font-mono text-text-muted">
            <span>{entry.data.researchOutput.toLocaleString()} papers</span>
            <span>{entry.data.topInstitutions.length} institutions</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <BottomCTA />
</Base>
