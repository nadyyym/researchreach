---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import { articleSchema } from '../../lib/seo';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

function slugFromId(id: string) {
  return id.replace(/\.md$/, '');
}

const { post } = Astro.props;
const { Content } = await render(post);

const pageTitle = `${post.data.title} — Sci-Buy Blog`;
const pageDesc = post.data.description;
const dateFormatted = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const slug = slugFromId(post.id);
const extraSchemas = [
  articleSchema({
    url: `/blog/${slug}/`,
    headline: post.data.title,
    description: post.data.description,
    author: post.data.author,
    datePublished: post.data.date,
    keywords: post.data.tags,
  }),
];
---

<Base title={pageTitle} description={pageDesc} extraSchemas={extraSchemas} speakableSelectors={['h1', 'article p:first-of-type']}>
  <Breadcrumb items={[
    { name: 'Blog', url: '/blog/' },
    { name: post.data.title, url: `/blog/${slugFromId(post.id)}/` },
  ]} />

  <article class="border-b border-line">
    <!-- HEADER -->
    <div class="px-6 py-12 md:px-12 md:py-16 max-w-3xl">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">{dateFormatted}</span>
        <span class="w-px h-3 bg-line-accent"></span>
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">{post.data.author}</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-light text-text-bright tracking-tight mb-4 leading-[1.3]">
        {post.data.title}
      </h1>
      <p class="text-[13px] text-text-dim leading-relaxed">
        {post.data.description}
      </p>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {post.data.tags.map((tag) => (
            <span class="px-2 py-1 bg-bg-raised border border-line text-[9px] text-text-muted font-mono uppercase tracking-[2px]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- CONTENT -->
    <div class="px-6 md:px-12 pb-16 max-w-3xl prose-scibuy">
      <Content />
    </div>
  </article>

  <BottomCTA />
</Base>

<style is:global>
  .prose-scibuy h2 {
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--color-text-bright);
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-scibuy h2 strong { font-weight: 600; }
  .prose-scibuy h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-bright);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-scibuy p {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .prose-scibuy ul, .prose-scibuy ol {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose-scibuy li { margin-bottom: 0.375rem; }
  .prose-scibuy strong { color: var(--color-text-bright); font-weight: 600; }
  .prose-scibuy a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }
  .prose-scibuy a:hover { color: var(--color-text-bright); }
  .prose-scibuy code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    background: var(--color-bg-raised);
    padding: 0.125rem 0.375rem;
  }
  .prose-scibuy pre {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-line);
    padding: 1rem;
    margin-bottom: 1rem;
    overflow-x: auto;
  }
  .prose-scibuy pre code {
    background: none;
    padding: 0;
    font-size: 0.75rem;
    color: var(--color-text);
  }
  .prose-scibuy table {
    width: 100%;
    font-size: 0.75rem;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }
  .prose-scibuy th {
    text-align: left;
    padding: 0.5rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-text-bright);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .prose-scibuy td {
    padding: 0.5rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-text-dim);
  }
  .prose-scibuy blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-dim);
    font-style: italic;
  }
</style>
