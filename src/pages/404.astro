---
import Base from "../layouts/Base.astro";
import "../styles/global.css";
---

<Base
  title="404 — Page Not Found | Sci-Buy"
  description="Page not found."
  robots="noindex"
>
  <main class="flex items-center justify-center min-h-[60vh]">
    <div class="px-6 py-24 text-center max-w-lg">
      <span class="font-mono text-[72px] text-line-accent block mb-6">404</span>
      <h1 class="text-2xl font-light text-text-bright mb-3">
        Researcher <strong class="font-semibold">not found.</strong>
      </h1>
      <p class="text-[13px] text-text-dim leading-relaxed mb-10 max-w-[360px] mx-auto">
        This page does not exist -- but the research graph does. Head back and find the scientists you are looking for.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="px-6 py-3 bg-red text-text-bright border border-red-btn font-mono text-[10px] tracking-[1.5px] uppercase no-underline hover:bg-red-btn transition-colors"
        >
          Back to home
        </a>
        <a
          href="#waitlist"
          class="px-6 py-3 border border-line text-text-dim font-mono text-[10px] tracking-[1.5px] uppercase no-underline hover:border-accent-dim hover:text-text-bright transition-colors"
        >
          Join the waitlist
        </a>
      </div>
    </div>
  </main>
</Base>
