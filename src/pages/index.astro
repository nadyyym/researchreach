---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import InstallCommand from "../components/InstallCommand.astro";
import TerminalMockup from "../components/TerminalMockup.astro";
import WaitlistForm from "../components/WaitlistForm.astro";
import BottomCTA from "../components/BottomCTA.astro";
import { softwareSchema } from "../lib/seo";
import "../styles/global.css";

// Sample N entries from a collection, sorted by id for stable build output.
function sample<T extends { id: string; data: { name: string } }>(
  entries: T[],
  count: number,
): { id: string; name: string }[] {
  return [...entries]
    .sort((a, b) => a.id.localeCompare(b.id))
    .slice(0, count)
    .map((e) => ({ id: e.id, name: e.data.name }));
}

const browseSections = [
  { slug: "universities", label: "Universities", items: sample(await getCollection("universities"), 6) },
  { slug: "fields", label: "Fields", items: sample(await getCollection("fields"), 6) },
  { slug: "researchers", label: "Researchers", items: sample(await getCollection("researchers"), 6) },
  { slug: "phd", label: "PhD & Postdocs", items: sample(await getCollection("phd"), 6) },
  { slug: "countries", label: "Countries", items: sample(await getCollection("countries"), 6) },
  { slug: "agencies", label: "Funding Agencies", items: sample(await getCollection("agencies"), 6) },
  { slug: "companies", label: "Companies", items: sample(await getCollection("companies"), 6) },
  { slug: "industries", label: "Industries", items: sample(await getCollection("industries"), 6) },
];

const categories = [
  { name: "Universities", slug: "universities", count: "4,000+", accent: "accent-top-red", span: true },
  { name: "Fields", slug: "fields", count: "250+", accent: "accent-top-blue" },
  { name: "Researchers", slug: "researchers", count: "100M+", accent: "accent-top-yellow" },
  { name: "PhD & Postdocs", slug: "phd", count: "2M+", accent: "accent-top-red" },
  { name: "Countries", slug: "countries", count: "195", accent: "accent-top-blue" },
  { name: "Agencies", slug: "agencies", count: "500+", accent: "accent-top-yellow" },
  { name: "Companies", slug: "companies", count: "10K+", accent: "accent-top-red" },
  { name: "Industries", slug: "industries", count: "50+", accent: "accent-top-blue" },
];

const terminalLines = [
  { type: 'prompt' as const, text: 'npx sci-buy search "CRISPR gene editing" --institution Stanford' },
  { type: 'blank' as const, text: '' },
  { type: 'output' as const, text: '<span class="text-text-muted">Searching 250M+ papers...</span>' },
  { type: 'blank' as const, text: '' },
  { type: 'success' as const, text: '47 researchers found' },
  { type: 'blank' as const, text: '' },
  { type: 'output' as const, text: '<span class="text-accent">01</span>  Dr. Sarah Chen · Stanford · H-index: 32' },
  { type: 'output' as const, text: '    <span class="text-text-muted">4 patents · NIH R01 · $2.1M active funding</span>' },
  { type: 'output' as const, text: '    <span class="text-text-muted">s.chen@stanford.edu · confidence: high</span>' },
  { type: 'blank' as const, text: '' },
  { type: 'output' as const, text: '<span class="text-accent">02</span>  Prof. Michael Torres · Stanford · H-index: 45' },
  { type: 'output' as const, text: '    <span class="text-text-muted">7 patents · NIH R01 · $3.8M active funding</span>' },
  { type: 'output' as const, text: '    <span class="text-text-muted">m.torres@stanford.edu · confidence: high</span>' },
  { type: 'blank' as const, text: '' },
  { type: 'output' as const, text: '<span class="text-text-muted">... 45 more results</span>' },
];
---

<Base
  title="Sci-Buy — Research Intelligence CLI"
  description="Find and reach the scientists who need your product. Search 250M+ papers, map researchers by field, H-index, grants, and industry ties. Export verified contacts."
  extraSchemas={[softwareSchema()]}
>
  <main>
    <!-- HERO -->
    <section class="border-b border-line relative">
      <img src="/illustrations/hero-grid.svg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-40 pointer-events-none" aria-hidden="true" />
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] grid-lines relative z-10">
        <div class="bg-bg/80 p-8 md:p-12 lg:p-16 flex flex-col justify-center">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-6">Research Intelligence CLI</span>
          <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-4 leading-[1.2]">
            Find the scientists<br />
            <span class="text-accent font-semibold">who need your product.</span>
          </h1>
          <p class="text-[13px] text-text-dim leading-relaxed max-w-[420px] mb-8">
            Search 250M+ papers. Map researchers by field, H-index, grants, and industry ties. Export verified contacts. All from your terminal.
          </p>
          <div class="mb-6">
            <InstallCommand />
          </div>
          <div class="flex items-center gap-3 mb-4">
            <div class="flex-1 h-px bg-line"></div>
            <span class="text-[10px] text-text-muted uppercase tracking-[2px]">or join the waitlist</span>
            <div class="flex-1 h-px bg-line"></div>
          </div>
          <WaitlistForm compact />
        </div>
        <div class="bg-bg/80 p-8 md:p-12 lg:p-16 flex items-center">
          <TerminalMockup lines={terminalLines} />
        </div>
      </div>
    </section>

    <!-- CATEGORY PORTAL -->
    <section class="border-b border-line">
      <div class="px-6 py-10 md:px-12 md:py-14">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">Browse the Research Graph</span>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr] grid-lines auto-rows-auto">
        <!-- Featured: Universities (spans 2 rows) -->
        <a href="/universities/" class="bg-bg p-8 md:p-10 row-span-2 border-r border-red-dim flex flex-col justify-between no-underline group hover:bg-bg-raised transition-colors">
          <div>
            <span class="font-mono text-[9px] tracking-[2px] uppercase text-red">{categories[0].name}</span>
            <p class="text-2xl font-light text-text-bright mt-3 group-hover:text-accent transition-colors">{categories[0].count}</p>
            <p class="text-[11px] text-text-dim mt-1.5">institutions indexed</p>
          </div>
          <span class="font-mono text-[10px] text-text-muted group-hover:text-text-dim transition-colors">Explore --&gt;</span>
        </a>
        <!-- Remaining 7 categories -->
        {categories.slice(1).map(cat => (
          <a href={`/${cat.slug}/`} class:list={['bg-bg p-5 md:p-6 no-underline group hover:bg-bg-raised transition-colors flex flex-col justify-between', cat.accent]}>
            <div>
              <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">{cat.name}</span>
              <p class="text-lg font-light text-text-bright mt-2 group-hover:text-accent transition-colors">{cat.count}</p>
            </div>
            <span class="font-mono text-[10px] text-text-muted group-hover:text-text-dim transition-colors mt-3">--&gt;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- BROWSE THE INDEX (sample detail pages from each collection) -->
    <section class="border-b border-line">
      <div class="px-6 py-10 md:px-12 md:py-14 border-b border-line">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">Browse the Index</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 grid-lines">
        {browseSections.map((sec) => (
          <div class="bg-bg p-6">
            <a href={`/${sec.slug}/`} class="font-mono text-[10px] tracking-[2px] uppercase text-text-bright hover:text-accent transition-colors no-underline block mb-3">
              {sec.label} &rarr;
            </a>
            <ul class="flex flex-col gap-1.5">
              {sec.items.map((item) => (
                <li>
                  <a href={`/${sec.slug}/${item.id}/`} class="text-[12px] text-text-dim hover:text-text-bright no-underline transition-colors">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="border-b border-line">
      <div class="px-6 py-10 md:px-12 md:py-14 border-b border-line">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted">How It Works</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 grid-lines">
        <div class="bg-bg p-8 md:p-10 border-b border-red-dim md:border-b-0" style="border-bottom: 1px solid var(--color-red-dim);">
          <span class="font-mono text-[32px] text-line-accent block mb-5">01</span>
          <h3 class="text-lg font-light text-text-bright mb-2.5">
            <strong class="font-semibold">Search</strong> the graph
          </h3>
          <p class="text-[12px] text-text-dim leading-relaxed">
            Query 250M+ papers by field, institution, funding, and keywords. Filter by NIH/NSF grants, H-index, publication recency.
          </p>
        </div>
        <div class="bg-bg p-8 md:p-10" style="border-bottom: 1px solid var(--color-accent-dim);">
          <span class="font-mono text-[32px] text-line-accent block mb-5">02</span>
          <h3 class="text-lg font-light text-text-bright mb-2.5">
            <strong class="font-semibold">Map</strong> researchers
          </h3>
          <p class="text-[12px] text-text-dim leading-relaxed">
            Surface industry bridge signals: patent holders, startup co-founders, SAB members, industry-funded PIs, and recent transitions.
          </p>
        </div>
        <div class="bg-bg p-8 md:p-10" style="border-bottom: 1px solid var(--color-yellow-dim);">
          <span class="font-mono text-[32px] text-line-accent block mb-5">03</span>
          <h3 class="text-lg font-light text-text-bright mb-2.5">
            <strong class="font-semibold">Export</strong> contacts
          </h3>
          <p class="text-[12px] text-text-dim leading-relaxed">
            Get verified institutional emails, ORCID profiles, H-index, grant amounts, and citations. Export to CSV or pipe to your CRM.
          </p>
        </div>
      </div>
    </section>

    <!-- WHO USES SCI-BUY -->
    <section class="border-b border-line">
      <div class="bg-red-dim px-6 py-3 md:px-12">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-dim">Who Uses Sci-Buy</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1fr_200px] grid-lines">
        <a href="/use-cases/#pharma" class="bg-bg p-8 no-underline group hover:bg-bg-raised transition-colors">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-red mb-3 block">Pharma & Biotech</span>
          <p class="text-[13px] text-text-bright font-light mb-2 group-hover:text-accent transition-colors">KOL identification, drug discovery outreach</p>
          <p class="text-[11px] text-text-muted leading-relaxed">Find PIs with active grants. Identify researchers with industry co-authorships and patent filings.</p>
        </a>
        <a href="/use-cases/#software" class="bg-bg p-8 no-underline group hover:bg-bg-raised transition-colors">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-accent mb-3 block">Scientific Software</span>
          <p class="text-[13px] text-text-bright font-light mb-2 group-hover:text-accent transition-colors">ELN, LIMS, and lab automation sales</p>
          <p class="text-[11px] text-text-muted leading-relaxed">Reach lab managers running wet labs in your target verticals. Segment by lab size and funding level.</p>
        </a>
        <a href="/use-cases/#recruiting" class="bg-bg p-8 no-underline group hover:bg-bg-raised transition-colors">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-yellow mb-3 block">Deep Tech Recruiting</span>
          <p class="text-[13px] text-text-bright font-light mb-2 group-hover:text-accent transition-colors">Source PhD researchers with industry signals</p>
          <p class="text-[11px] text-text-muted leading-relaxed">Filter by patent filings, startup affiliations, or recent academia-to-industry transitions.</p>
        </a>
        <div class="bg-bg p-8 flex flex-col justify-center items-center text-center">
          <span class="font-mono text-[32px] text-text-bright block mb-1">200+</span>
          <span class="text-[11px] text-text-muted">teams on waitlist</span>
        </div>
      </div>
    </section>

    <!-- TRUST BAR -->
    <section class="border-b border-line">
      <div class="px-6 py-6 md:px-12 flex flex-wrap items-center justify-center gap-x-3 gap-y-2">
        <span class="font-mono text-[10px] text-text-muted tracking-[1px]">DATA SOURCES:</span>
        <span class="text-text-muted">|</span>
        <span class="font-mono text-[11px] text-text-dim">OpenAlex</span>
        <span class="text-text-muted">|</span>
        <span class="font-mono text-[11px] text-text-dim">ORCID</span>
        <span class="text-text-muted">|</span>
        <span class="font-mono text-[11px] text-text-dim">PubMed</span>
        <span class="text-text-muted">|</span>
        <span class="font-mono text-[11px] text-text-dim">NIH Reporter</span>
        <span class="text-text-muted">|</span>
        <span class="font-mono text-[11px] text-text-dim">Semantic Scholar</span>
        <span class="text-text-muted">|</span>
        <span class="font-mono text-[11px] text-text-dim">USPTO</span>
      </div>
    </section>

    <!-- BOTTOM CTA -->
    <BottomCTA />
  </main>
</Base>
