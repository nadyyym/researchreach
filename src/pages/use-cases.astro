---
import Base from "../layouts/Base.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import TerminalMockup from "../components/TerminalMockup.astro";
import BottomCTA from "../components/BottomCTA.astro";
import "../styles/global.css";

const pharmaTerminal = [
  { type: 'prompt' as const, text: 'sci-buy search "GLP-1 receptor" --grants NIH --signals industry' },
  { type: 'blank' as const, text: '' },
  { type: 'success' as const, text: '52 KOLs found with industry ties' },
  { type: 'output' as const, text: '<span class="text-accent">01</span>  Dr. Elena Ruiz · UCSF · H-index: 38' },
  { type: 'output' as const, text: '    <span class="text-text-muted">3 patents · Novo Nordisk SAB · $2.4M NIH R01</span>' },
];

const softwareTerminal = [
  { type: 'prompt' as const, text: 'sci-buy search "proteomics" --min-hindex 15 --institution-type R1' },
  { type: 'blank' as const, text: '' },
  { type: 'success' as const, text: '310 lab PIs matched' },
  { type: 'output' as const, text: '<span class="text-accent">01</span>  Prof. David Park · Johns Hopkins · H-index: 27' },
  { type: 'output' as const, text: '    <span class="text-text-muted">Wet lab · 8 grad students · $1.2M active funding</span>' },
];

const recruitingTerminal = [
  { type: 'prompt' as const, text: 'sci-buy map --field "quantum computing" --signals patents,startups' },
  { type: 'blank' as const, text: '' },
  { type: 'success' as const, text: '18 researchers with transition signals' },
  { type: 'output' as const, text: '<span class="text-accent">01</span>  Dr. Wei Zhang · Caltech · H-index: 22' },
  { type: 'output' as const, text: '    <span class="text-text-muted">2 patents · ex-Google Quantum AI · postdoc</span>' },
];

const vcTerminal = [
  { type: 'prompt' as const, text: 'sci-buy map --field "mRNA therapeutics" --signals patents --min-patents 3' },
  { type: 'blank' as const, text: '' },
  { type: 'success' as const, text: '9 high-patent researchers found' },
  { type: 'output' as const, text: '<span class="text-accent">01</span>  Prof. Anya Patel · Penn · H-index: 44' },
  { type: 'output' as const, text: '    <span class="text-text-muted">7 patents · 2 SBIR grants · CRISPRx Bio co-founder</span>' },
];
---

<Base
  title="Use Cases — Sci-Buy CLI"
  description="How pharma BD teams, scientific software vendors, deep tech recruiters, and life sciences VCs use Sci-Buy to find and reach academic researchers."
>
  <main>
    <Breadcrumb items={[{ name: "Use Cases", url: "/use-cases/" }]} />

    <!-- HERO -->
    <section class="border-b border-line">
      <div class="px-6 py-16 md:px-12 md:py-24 max-w-4xl">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-6 block">Use Cases</span>
        <h1 class="text-3xl md:text-4xl font-light text-text-bright tracking-tight mb-4 leading-[1.2]">
          Four buyer types.<br />
          <strong class="font-semibold">Same invisible market.</strong>
        </h1>
        <p class="text-[13px] text-text-dim leading-relaxed max-w-[480px]">
          Whether you sell, recruit, or invest in the scientific community, Sci-Buy gives you the contacts and signals that B2B tools miss entirely.
        </p>
      </div>
    </section>

    <!-- PHARMA & BIOTECH -->
    <section id="pharma" class="border-b border-line">
      <div class="bg-red-dim px-6 py-3 md:px-12">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-dim">01 / Pharma & Biotech Outreach</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 grid-lines">
        <div class="bg-bg p-8 md:p-12">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-4 block">The Persona</span>
          <p class="text-[13px] text-text leading-relaxed mb-6">
            BD teams, KOL programs, medical affairs, CRO sourcing. A business development lead at a mid-size biotech needs to build a list of 50 KOLs in GLP-1 receptor research. Getting verified contacts and understanding industry ties takes weeks with current tools.
          </p>
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-3 block">How Sci-Buy Helps</span>
          <div class="space-y-2.5">
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Search by therapeutic area and active grant funding</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Filter by industry co-authorships and clinical trial affiliations</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Export verified institutional emails and ORCID profiles</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Patent filings to identify IP-generating researchers</p>
            </div>
          </div>
        </div>
        <div class="bg-bg p-8 md:p-12 flex flex-col justify-center gap-6">
          <TerminalMockup lines={pharmaTerminal} />
          <div class="border border-line p-5">
            <p class="text-[12px] text-text-dim leading-relaxed italic">
              "We used to spend 3 weeks building KOL lists from scratch. With a tool like this, we could have that list ready in an afternoon."
            </p>
            <p class="text-[10px] text-text-muted mt-2 font-mono">-- Pharma BD Lead, waitlist member</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SCIENTIFIC SOFTWARE -->
    <section id="software" class="border-b border-line">
      <div class="px-6 py-3 md:px-12" style="background-color: var(--color-accent-dim);">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-dim">02 / Scientific Software Sales</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 grid-lines">
        <div class="bg-bg p-8 md:p-12 flex flex-col justify-center order-2 md:order-1">
          <TerminalMockup lines={softwareTerminal} />
        </div>
        <div class="bg-bg p-8 md:p-12 order-1 md:order-2">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-4 block">The Persona</span>
          <p class="text-[13px] text-text leading-relaxed mb-6">
            ELN vendors, LIMS, research platforms, lab automation. An AE at a lab software company is trying to grow their academic customer base. "Researcher" is not a job title that shows up in ZoomInfo.
          </p>
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-3 block">How Sci-Buy Helps</span>
          <div class="space-y-2.5">
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Segment by research methodology (wet lab, computational, clinical)</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Filter by lab size proxy (co-authors, grad student volume)</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Target by NIH grant amount as a budget signal</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">CRM sync via API or direct CSV export</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DEEP TECH RECRUITING -->
    <section id="recruiting" class="border-b border-line">
      <div class="px-6 py-3 md:px-12" style="background-color: var(--color-yellow-dim);">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-dim">03 / Deep Tech Recruiting</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 grid-lines">
        <div class="bg-bg p-8 md:p-12">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-4 block">The Persona</span>
          <p class="text-[13px] text-text leading-relaxed mb-6">
            Biotech startups, semicon firms, defense tech, quantum computing. A technical recruiter needs to hire 3 research scientists with background in superconducting qubits. LinkedIn returns zero relevant results.
          </p>
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-3 block">How Sci-Buy Helps</span>
          <div class="space-y-2.5">
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Find researchers by publication topic and methodology keyword</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Filter by industry bridge signals (startup affiliation, patents)</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Identify postdocs within 12 months of graduation</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">H-index and citation count as research quality signals</p>
            </div>
          </div>
        </div>
        <div class="bg-bg p-8 md:p-12 flex items-center">
          <TerminalMockup lines={recruitingTerminal} />
        </div>
      </div>
    </section>

    <!-- VC & DEAL SOURCING -->
    <section id="vc" class="border-b border-line">
      <div class="bg-red-dim px-6 py-3 md:px-12">
        <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-dim">04 / VC & Deal Sourcing</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 grid-lines">
        <div class="bg-bg p-8 md:p-12 flex items-center order-2 md:order-1">
          <TerminalMockup lines={vcTerminal} />
        </div>
        <div class="bg-bg p-8 md:p-12 order-1 md:order-2">
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-4 block">The Persona</span>
          <p class="text-[13px] text-text leading-relaxed mb-6">
            Life sciences funds, deep tech VCs, university tech transfer. A partner at a life sciences VC wants to monitor emerging research before companies spin out of universities.
          </p>
          <span class="font-mono text-[9px] tracking-[2px] uppercase text-text-muted mb-3 block">How Sci-Buy Helps</span>
          <div class="space-y-2.5">
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Track patent filing velocity by researcher and institution</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Monitor NIH SBIR/STTR grants (the pre-spinout signal)</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Identify researchers with multiple patents + startup experience</p>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-[10px] text-accent mt-0.5">+</span>
              <p class="text-[12px] text-text">Export co-author networks to map scientific communities</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BOTTOM CTA -->
    <BottomCTA />
  </main>
</Base>
